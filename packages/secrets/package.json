    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@icp/db": "workspace:*",
    "@icp/logger": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
