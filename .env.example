# ─── Infra ───
DATABASE_URL="postgresql://icp:icp_local@localhost:5432/icp_prospector?schema=public"
REDIS_URL="redis://localhost:6379"

# Criptografia das chaves de API guardadas no banco (32 bytes: hex 64 chars OU base64).
# Gere: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=""

# NOTA: as chaves abaixo são OPCIONAIS no .env — podem ser inseridas pela UI em /settings
# (ficam criptografadas no banco e têm prioridade sobre estas variáveis).

# ─── AI (pluggable — ver ADR-0002) ───
LLM_PROVIDER="claude"            # claude | openai
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
# override de modelo por task (opcional)
MODEL_BULK="claude-sonnet-4-6"   # análise em massa
MODEL_LONGFORM="claude-opus-4-8" # LP / copy longa
MODEL_VISION="claude-opus-4-8"   # análise visual

# ─── Fontes (hybrid — ver ADR-0003) ───
GOOGLE_PLACES_API_KEY=""         # descoberta (primária)
PAGESPEED_API_KEY=""             # PageSpeed Insights / Lighthouse
GOOGLE_MAPS_API_KEY=""           # geocoding (opcional)
META_AD_LIBRARY_TOKEN=""         # confirma anúncios ativos (Meta Ad Library); heurística roda sem isso

# toggles de collectors
COLLECTOR_PLACES_ENABLED="true"
COLLECTOR_CNPJ_ENABLED="true"    # BrasilAPI/ReceitaWS (público)
COLLECTOR_APIFY_ENABLED="false"  # actors pagos (assume risco ToS no provider)
APIFY_TOKEN=""

# social só via API/flag — scraping de IG/LinkedIn DESLIGADO por padrão
SOCIAL_ANALYSIS_ENABLED="false"

# ─── LP host ───
LP_BASE_URL="http://localhost:3000/lp"   # ou https://preview.suaagencia.com

# ─── Limites / custo (F8) ───
LLM_BUDGET_USD_PER_CAMPAIGN="10"   # 0 = sem limite; estoura → fallback por regra
MAX_CONCURRENCY_ANALYZE="20"       # estágio ANALYZE (rede/PSI)
MAX_CONCURRENCY_AI="3"             # estágios LLM (opportunities/proposal/landing/messages)
MAX_CONCURRENCY_DEFAULT="5"        # demais estágios

# ─── Auth (scaffold multi-tenant — F8) ───
# Se setado, rotas de escrita exigem header: Authorization: Bearer <token>.
# Vazio = modo dev (libera).
ADMIN_TOKEN=""
